<UserControl x:Class="BgaDefectViewer.Views.OverlapInspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BgaDefectViewer.Controls">
    <DockPanel>

        <!-- Bottom: Summary bar -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="8,4">
            <TextBlock Text="{Binding SummaryText}" FontFamily="Consolas" FontSize="12"/>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Ball Map + FOV Overlay -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                    <Button Content="FIT" Command="{Binding FitViewCommand}"
                            Padding="8,2" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ClusterCenterText}" Foreground="Green"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <Border Background="#1E1E1E" ClipToBounds="True">
                    <Grid>
                        <controls:BallMapCanvas x:Name="BallCanvas"/>
                        <controls:FovOverlayCanvas x:Name="FovOverlay" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- Right: Parameter Panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">

                    <!-- Enable Overlap Inspection (KBGA Settings checkbox) -->
                    <CheckBox Content="Enable Overlap Inspection"
                              IsChecked="{Binding EnableOverlapInspection}"
                              FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                    <!-- Display layers -->
                    <TextBlock Text="Display layers" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <CheckBox Content="Camera raw image (actual photo)"
                              IsChecked="{Binding ShowCameraRawLayer}" Margin="0,0,0,2"/>
                    <CheckBox Content="FOV (logical inspection)"
                              IsChecked="{Binding ShowFovLayer}" Margin="0,0,0,2"/>
                    <CheckBox Content="Effective area (FOV − mask)"
                              IsChecked="{Binding ShowEffectiveLayer}" Margin="0,0,0,8"/>

                    <!-- Camera raw size -->
                    <TextBlock Text="Camera raw size [mm]" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox SelectedIndex="{Binding CameraTypeIndex}" Margin="0,0,0,4">
                        <ComboBoxItem Content="Normal view (94.52 × 62.87)"/>
                        <ComboBoxItem Content="Enlarged view (109.66 × 72.95)"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>
                    <Grid IsEnabled="{Binding IsCameraCustom}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="1" Text="{Binding CameraRawX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="3" Text="{Binding CameraRawY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- Execute Button -->
                    <Button Content="Execute" Command="{Binding ExecuteCommand}"
                            FontWeight="Bold" FontSize="14" Padding="12,6" Margin="0,0,0,8"
                            HorizontalAlignment="Stretch"
                            Background="#0078D7" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding EnableOverlapInspection}"/>

                    <!-- Validation errors -->
                    <TextBlock Text="{Binding ValidationErrors}" Foreground="Red"
                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <!-- Result info (auto-calculated FOV count, move dist) -->
                    <TextBlock Text="{Binding ResultInfo}" Foreground="#3399FF"
                               FontFamily="Consolas" FontSize="11" Margin="0,0,0,4"/>

                    <Separator Margin="0,4"/>

                    <!-- Device Area -->
                    <TextBlock Text="Device Area [mm]" FontWeight="Bold" FontSize="13" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="1" Text="{Binding DeviceAreaX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="3" Text="{Binding DeviceAreaY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- FOV -->
                    <TextBlock Text="FOV [mm]" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="1" Text="{Binding FovSizeX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="3" Text="{Binding FovSizeY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- Overlapping length -->
                    <TextBlock Text="Overlapping length with adjacent FOV [mm]"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="1" Text="{Binding OverlapLengthX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="3" Text="{Binding OverlapLengthY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- Boundary mask -->
                    <TextBlock Text="Boundary mask length [mm]"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="1" Text="{Binding BoundaryMaskX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Column="3" Text="{Binding BoundaryMaskY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- Is staggered pattern -->
                    <CheckBox Content="Is staggered pattern?" IsChecked="{Binding IsStaggeredPattern}" Margin="0,0,0,4"/>

                    <Separator Margin="0,8"/>

                    <!-- Ball duplication -->
                    <TextBlock Text="Ball duplication judgment allowance [pix]"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <TextBox Text="{Binding DuplicationAllowancePix}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    <TextBlock FontWeight="Bold" FontSize="12" Margin="0,4,0,0"
                               Foreground="OrangeRed" FontFamily="Consolas">
                        <Run Text="Duplicates found: "/><Run Text="{Binding TotalDuplicates, Mode=OneWay}"/>
                    </TextBlock>

                    <Separator Margin="0,8"/>

                    <!-- Alignment Marks -->
                    <TextBlock Text="Alignment FOV position" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Align. 1  X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Align1FovX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Align1FovY}" Margin="0,0,0,2" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Align. 2  X:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Align2FovX}" Margin="0,0,8,2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,2"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Align2FovY}" Margin="0,0,0,2" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8"/>

                    <!-- Per-FOV Ball Count Table -->
                    <TextBlock Text="Balls per FOV" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                    <DataGrid ItemsSource="{Binding FovBallCounts}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" MaxHeight="250"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="#CCCCCC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Scan#" Binding="{Binding ScanIndex}" Width="55"/>
                            <DataGridTextColumn Header="Grid" Binding="{Binding GridPosition}" Width="65"/>
                            <DataGridTextColumn Header="Balls" Binding="{Binding BallCount}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
