<UserControl x:Class="BgaDefectViewer.Views.RecurringDefectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BgaDefectViewer.Controls"
             xmlns:converters="clr-namespace:BgaDefectViewer.Converters"
             xmlns:helpers="clr-namespace:BgaDefectViewer.Helpers">

    <UserControl.Resources>
        <converters:CountToColorConverter x:Key="CountToColor"/>
        <converters:DefectCodeToColorConverter x:Key="DefectColorConv"/>
        <helpers:BindingProxy x:Key="ColsProxy" Data="{Binding GridColumns}"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#ECEFF1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="固定欠陥 (Recurring Defects)" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" | " Foreground="Gray" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HeaderText}" FontSize="12"
                           VerticalAlignment="Center" Foreground="#555"/>
            </StackPanel>
        </Border>

        <!-- Bottom filter bar (two rows) -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="8,6">
            <StackPanel>
                <!-- Row 1: 連続欠陥回数 radio buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="連続欠陥回数:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton x:Name="Rb1"  Content="1~"  Tag="1"  IsChecked="True" Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb2"  Content="2~"  Tag="2"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb3"  Content="3~"  Tag="3"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb4"  Content="4~"  Tag="4"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb5"  Content="5~"  Tag="5"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb6"  Content="6~"  Tag="6"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb7"  Content="7~"  Tag="7"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb8"  Content="8~"  Tag="8"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb9"  Content="9~"  Tag="9"  Click="FilterBtn_Click" Margin="2,0"/>
                    <RadioButton x:Name="Rb10" Content="10~" Tag="10" Click="FilterBtn_Click" Margin="2,0"/>
                </StackPanel>
                <!-- Row 2: 欠陥種類 checkboxes (bound to DefectTypeFilters) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="欠陥種類:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ItemsControl ItemsSource="{Binding DefectTypeFilters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="全選" Command="{Binding SelectAllDefectTypesCommand}"
                            Padding="6,1" Margin="12,0,2,0" VerticalAlignment="Center"/>
                    <Button Content="全不選" Command="{Binding ClearAllDefectTypesCommand}"
                            Padding="6,1" Margin="2,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main 3-panel layout: Die grid | Ball map | Detail table.
             Left column is Auto-sized so a wider Die matrix expands the panel; capped via
             MaxWidth so the middle canvas keeps a usable area. The user can still drag the
             GridSplitter to override (which pins the column to a pixel value). -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="220" MaxWidth="520"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <!-- Right detail panel: default 340 so the star-sized Judge column
                     can fit "Missing" (longest defect name) without truncation.
                     Middle canvas is star-sized so it auto-shrinks as the right
                     panel grows. MinWidth keeps splitter-drag usable. -->
                <ColumnDefinition Width="340" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Die grid ──────────────────────────────────────── -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Die Recurring Count"
                           FontSize="11" FontWeight="Bold" Margin="4,4,4,2" Foreground="#444"/>
                <!-- Metric mode: Max (worst single ball) vs Count (number of recurring positions) -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,4,4">
                    <TextBlock Text="表示:" VerticalAlignment="Center"
                               FontSize="11" Foreground="#666" Margin="0,0,4,0"/>
                    <RadioButton Content="最大次数" GroupName="DieMetric"
                                 IsChecked="{Binding IsDieMetricMax, Mode=TwoWay}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"
                                 ToolTip="該 Die 內單一球出現的最大次數"/>
                    <RadioButton Content="重複点数" GroupName="DieMetric"
                                 IsChecked="{Binding IsDieMetricCount, Mode=TwoWay}"
                                 VerticalAlignment="Center"
                                 ToolTip="該 Die 內出現次數 ≥ 閾值 的球位數量"/>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DieGridItems"
                                  ItemsSource="{Binding DieGrid}"
                                  MouseLeftButtonDown="DieGrid_MouseLeftButtonDown">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding Data, Source={StaticResource ColsProxy}}"
                                             HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="36" Height="36" Margin="0"
                                        ToolTip="{Binding ActualCount, StringFormat='Count: {0}'}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="#999"/>
                                            <Setter Property="Background"
                                                    Value="{Binding DisplayCount,
                                                        Converter={StaticResource CountToColor},
                                                        ConverterParameter=Background}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                    <Setter Property="Background" Value="#00ACC1"/>
                                                    <Setter Property="BorderBrush" Value="#007C91"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{Binding DisplayCount,
                                                            Converter={StaticResource CountToColor},
                                                            ConverterParameter=Foreground}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- ── Centre: Ball map ────────────────────────────────────── -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                    <Button Content="FIT" Width="40" Height="22" Click="FitBtn_Click"/>
                </StackPanel>
                <Border x:Name="BallMapViewport"
                        Background="#1E1E1E" ClipToBounds="True"
                        SizeChanged="BallMapViewport_SizeChanged">
                    <controls:BallMapCanvas x:Name="BallCanvas"/>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>

            <!-- ── Right: Detail table ─────────────────────────────────── -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding LocationsText}"
                           FontSize="13" FontWeight="Bold" Margin="4,4,4,2"/>
                <DataGrid x:Name="DetailDataGrid"
                          ItemsSource="{Binding DisplayedBalls}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="All"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          MouseDoubleClick="DetailDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding BallId}"   Width="55" MinWidth="50"/>
                        <DataGridTextColumn Header="X"  Binding="{Binding DisplayX}" Width="70" MinWidth="60"/>
                        <DataGridTextColumn Header="Y"  Binding="{Binding DisplayY}" Width="70" MinWidth="60"/>
                        <!-- N column: same count→colour palette as the Die grid + canvas markers,
                             with WCAG-paired foreground from the same converter. -->
                        <DataGridTemplateColumn Header="N" Width="40" MinWidth="40" SortMemberPath="Count">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Count}"
                                               Background="{Binding Count, Converter={StaticResource CountToColor}, ConverterParameter=Background}"
                                               Foreground="{Binding Count, Converter={StaticResource CountToColor}, ConverterParameter=Foreground}"
                                               Padding="6,2" FontWeight="Bold"
                                               TextAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- Judge column: defect-type colour chip, matching SubstrateViewer's
                             Judge cell styling so Missing/Shift/Bridge/Extra/etc are recognisable
                             at a glance from their colour. -->
                        <DataGridTemplateColumn Header="Judge" Width="*" MinWidth="75" SortMemberPath="Judge">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Judge}"
                                               Background="{Binding DominantDefectCode, Converter={StaticResource DefectColorConv}}"
                                               Padding="4,2" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

    </DockPanel>
</UserControl>
