<UserControl x:Class="BgaDefectViewer.Views.SubstrateMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BgaDefectViewer.Converters"
             xmlns:helpers="clr-namespace:BgaDefectViewer.Helpers"
             xmlns:models="clr-namespace:BgaDefectViewer.Models">

    <UserControl.Resources>
        <converters:DieLetterToColorConverter x:Key="DieLetterToColor"/>
        <!-- BindingProxy lets UniformGrid inside ItemsPanelTemplate bind to GridColumns -->
        <helpers:BindingProxy x:Key="ColsProxy" Data="{Binding GridColumns}"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2">
            <Button x:Name="FitBtn" DockPanel.Dock="Right"
                    Content="FIT" Width="40" Height="22"
                    VerticalAlignment="Center" Margin="4,0,0,0"
                    Click="FitBtn_Click"/>
            <TextBlock Text="Substrate Map" FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,16,0"/>
            <TextBlock Text="INSPECTION:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox ItemsSource="{Binding InspectionNumbers}"
                      SelectedItem="{Binding SelectedInspection}"
                      Width="80" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SubstrateMaps.Count, StringFormat=' ({0} 片)'}"
                       VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0"/>
        </DockPanel>

        <!-- Main: left tile list | splitter | right zoomable die-grid -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="120"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: substrate vertical list -->
            <ListBox Grid.Column="0"
                     x:Name="SubstrateListBox"
                     ItemsSource="{Binding SubstrateMaps}"
                     SelectedItem="{Binding SelectedSubstrateMap}"
                     SelectionChanged="SubstrateListBox_SelectionChanged"
                     MouseDoubleClick="SubstrateListBox_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <!-- Remove default ListBoxItem chrome; add blue border on IsSelected -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="1,1,1,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1976D2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <!-- Vertical list row: coloured tile + substrate ID + M/S/E counts -->
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:SubstrateMap}">
                        <StackPanel Background="Transparent">
                            <Grid Height="60" Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <!-- Coloured tile: PrimaryDefectChar (most frequent in current inspection) -->
                                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="4"
                                        VerticalAlignment="Center" Margin="2"
                                        ToolTip="{Binding SubstrateId}"
                                        Background="{Binding PrimaryDefectChar, Converter={StaticResource DieLetterToColor}, ConverterParameter=Background}">
                                    <TextBlock Text="{Binding PrimaryDefectChar}"
                                               FontSize="20" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryDefectChar, Converter={StaticResource DieLetterToColor}, ConverterParameter=Foreground}"/>
                                </Border>
                                <!-- Substrate ID -->
                                <TextBlock Grid.Column="1" Text="{Binding SubstrateId}"
                                           VerticalAlignment="Center" Margin="4,0"
                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                <!-- M/S/E counts for current inspection -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <TextBlock Text="{Binding TotalMiss,  StringFormat='M:{0}'}"
                                               FontSize="10" Foreground="#555"/>
                                    <TextBlock Text="{Binding TotalShift, StringFormat='S:{0}'}"
                                               FontSize="10" Foreground="#555"/>
                                    <TextBlock Text="{Binding TotalExtra, StringFormat='E:{0}'}"
                                               FontSize="10" Foreground="#555"/>
                                </StackPanel>
                            </Grid>
                            <!-- Inspection annotation: only shown when not INSPECTION=1 -->
                            <TextBlock Text="{Binding InspectionLabel}"
                                       HorizontalAlignment="Center"
                                       FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Foreground" Value="DarkOrange"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNotFirstInspection}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInspectionFallback}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Right: die-grid panel with zoom/pan -->
            <DockPanel Grid.Column="2">
                <!-- Stats bar -->
                <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="6,3">
                    <TextBlock Text="{Binding SubstrateStats}"
                               FontFamily="Consolas" FontSize="11" Foreground="#444"/>
                </Border>

                <!-- Viewport: handles zoom (wheel) and pan (left-drag) -->
                <Border x:Name="DieMapViewport"
                        ClipToBounds="True"
                        Background="#F8F8F8"
                        MouseWheel="DieMapViewport_MouseWheel"
                        MouseLeftButtonDown="DieMapViewport_MouseLeftButtonDown"
                        MouseMove="DieMapViewport_MouseMove"
                        MouseLeftButtonUp="DieMapViewport_MouseLeftButtonUp"
                        SizeChanged="DieMapViewport_SizeChanged">
                    <!-- Die grid: click = select cell; double-click = open Substrate Viewer -->
                    <ItemsControl x:Name="DieGridItemsControl"
                                  ItemsSource="{Binding CurrentDieGrid}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  MouseLeftButtonDown="DieGrid_MouseLeftButtonDown"
                                  MouseDoubleClick="DieGrid_MouseDoubleClick">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding Data, Source={StaticResource ColsProxy}}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="36" Height="36"
                                        Margin="0"
                                        ToolTip="{Binding Tooltip}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="#555"/>
                                            <Setter Property="Background"
                                                    Value="{Binding Letter, Converter={StaticResource DieLetterToColor}, ConverterParameter=Background}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                    <Setter Property="Background" Value="#00ACC1"/>
                                                    <Setter Property="BorderBrush" Value="#007C91"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2.5"/>
                                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{Binding Letter, Converter={StaticResource DieLetterToColor}, ConverterParameter=Foreground}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
