<Window x:Class="BgaDefectViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BgaDefectViewer.ViewModels"
        xmlns:views="clr-namespace:BgaDefectViewer.Views"
        Title="BGA Defect Viewer" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <DockPanel>
        <!-- Config Bar -->
        <Grid DockPanel.Dock="Top" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Source:" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="1" Text="{Binding AthleteSysPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Margin="4,0"/>
            <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowsePathCommand}"
                    VerticalAlignment="Center" Margin="4,0" Padding="8,2"/>
            <TextBlock Grid.Column="3" Text="Part#:" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <ComboBox Grid.Column="4" ItemsSource="{Binding PartNumbers}"
                      SelectedItem="{Binding SelectedPartNumber}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="Lot#:" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <ComboBox Grid.Column="6" ItemsSource="{Binding LotNumbers}"
                      SelectedItem="{Binding SelectedLotNumber}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}"/>
        </StatusBar>

        <!-- Tab Control（7 Tabs: 0=Settings / 1=LotMonitor / 2=SubstrateMap / 3=SubstrateViewer / 4=DefectMap / 5=RecurringDefects / 6=OverlapInspection） -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
            <TabItem Header="Lot Monitor">
                <views:LotMonitorView DataContext="{Binding LotMonitor}"/>
            </TabItem>
            <TabItem Header="Substrate Map">
                <views:SubstrateMapView DataContext="{Binding SubstrateMap}"/>
            </TabItem>
            <TabItem Header="Substrate Viewer">
                <views:SubstrateViewerView DataContext="{Binding SubstrateViewer}"/>
            </TabItem>
            <TabItem Header="Defect Map" IsEnabled="{Binding DefectMap.IsAvailable}">
                <views:DefectMapView DataContext="{Binding DefectMap}"/>
            </TabItem>
            <TabItem Header="Recurring Defects">
                <views:RecurringDefectView DataContext="{Binding RecurringDefect}"/>
            </TabItem>
            <TabItem Header="Overlap Inspection">
                <views:OverlapInspectionView DataContext="{Binding OverlapInspection}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
