<Window x:Class="BgaDefectViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BgaDefectViewer.ViewModels"
        xmlns:views="clr-namespace:BgaDefectViewer.Views"
        xmlns:simviews="clr-namespace:BgaDefectViewer.Simulation.Views"
        Title="BGA Defect Viewer" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <DockPanel>
        <!-- Config Bar -->
        <Grid DockPanel.Dock="Top" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Source:" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="1" Text="{Binding AthleteSysPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Margin="4,0"
                     ToolTip="資料來源根目錄 (含 kbgadata / kbgaresults)&#x0a;雙擊以在檔案總管中開啟此路徑"
                     MouseDoubleClick="SourcePathTextBox_MouseDoubleClick"/>
            <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowsePathCommand}"
                    VerticalAlignment="Center" Margin="4,0" Padding="8,2"/>
            <TextBlock Grid.Column="3" Text="Part#:" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <ComboBox Grid.Column="4" ItemsSource="{Binding PartNumbers}"
                      DisplayMemberPath="DisplayName" SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedPartNumber}" VerticalAlignment="Center"
                      ToolTip="料號 (該料號的 Lot 筆數會於背景載入)"/>
            <ComboBox Grid.Column="5" ItemsSource="{Binding SortOptions}"
                      DisplayMemberPath="Display" SelectedValuePath="Mode"
                      SelectedValue="{Binding PartSortMode}"
                      ToolTip="Part# 排序方式"
                      VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBlock Grid.Column="6" Text="Lot#:" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <ComboBox Grid.Column="7" ItemsSource="{Binding LotNumbers}"
                      DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                      SelectedValue="{Binding SelectedLotNumber}" VerticalAlignment="Center"
                      ToolTip="批號 (該批基板數會於背景載入)"/>
            <ComboBox Grid.Column="8" ItemsSource="{Binding SortOptions}"
                      DisplayMemberPath="Display" SelectedValuePath="Mode"
                      SelectedValue="{Binding LotSortMode}"
                      ToolTip="Lot# 排序方式"
                      VerticalAlignment="Center" Margin="4,0,0,0"/>
            <Button Grid.Column="9" Content="Reload" Command="{Binding ReloadLotCommand}"
                    ToolTip="Re-read all files for the current Part# / Lot#"
                    VerticalAlignment="Center" Margin="4,0" Padding="8,2"/>
        </Grid>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusText}"/>
        </StatusBar>

        <!-- Tab Control（7 Tabs: 0=Settings / 1=LotMonitor / 2=SubstrateMap / 3=SubstrateViewer / 4=DefectMap / 5=RecurringDefects / 6=OverlapInspection） -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
            <TabItem Header="Lot Monitor">
                <views:LotMonitorView DataContext="{Binding LotMonitor}"/>
            </TabItem>
            <TabItem Header="Substrate Map">
                <views:SubstrateMapView DataContext="{Binding SubstrateMap}"/>
            </TabItem>
            <TabItem Header="Substrate Viewer">
                <views:SubstrateViewerView DataContext="{Binding SubstrateViewer}"/>
            </TabItem>
            <TabItem Header="Defect Map" IsEnabled="{Binding DefectMap.IsAvailable}">
                <views:DefectMapView DataContext="{Binding DefectMap}"/>
            </TabItem>
            <TabItem Header="Recurring Defects">
                <views:RecurringDefectView DataContext="{Binding RecurringDefect}"/>
            </TabItem>
            <TabItem Header="Overlap Inspection">
                <views:OverlapInspectionView DataContext="{Binding OverlapInspection}"/>
            </TabItem>
            <TabItem Header="Simulator">
                <simviews:SimulatorView DataContext="{Binding Simulator}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
