<UserControl x:Class="BgaDefectViewer.Views.LotMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BgaDefectViewer.Converters">
    <UserControl.Resources>
        <conv:JudgeToRowColorConverter x:Key="JudgeToRowColorConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
            <TextBlock Text="Lot Monitor — " FontSize="14" FontWeight="Bold"/>
            <TextBlock Text="{Binding LotName}" FontSize="14" FontWeight="Bold"/>
            <TextBlock Text="    SubstratesCount: " Margin="20,0,0,0" FontSize="14"/>
            <TextBlock Text="{Binding SubstrateCount}" FontSize="14"/>
            <TextBlock Text="    DieCount: " Margin="12,0,0,0" FontSize="14"
                       ToolTip="所有 Die 數 = SubstrateCount × DIE/Sub"/>
            <TextBlock Text="{Binding TotalDieCount}" FontSize="14"/>
            <Button Content="合併批號" Command="{Binding MergeLotsCommand}"
                    Margin="24,0,0,0" Padding="10,2" VerticalAlignment="Center"
                    ToolTip="從現有 Lot# 清單合併出一個臨時批號（僅本次 session 有效，不修改檔案）"/>
            <Button Content="{Binding MountFilterButtonText}"
                    Command="{Binding MountFilterCommand}"
                    Margin="8,0,0,0" Padding="10,2" VerticalAlignment="Center"
                    ToolTip="依首次檢驗時間順序輪流分配 Mount，過濾顯示與統計 (雙/三植球機適用)">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMountFilterActive}" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                                <Setter Property="BorderBrush" Value="#FB8C00"/>
                                <Setter Property="Foreground" Value="#E65100"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- LOT Summary (bottom) -->
        <GroupBox DockPanel.Dock="Bottom" Margin="4" MaxHeight="360">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Indicator: Green = original CSV, Amber = app-calculated -->
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#43A047"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSummaryCalculated}" Value="True">
                                        <Setter Property="Fill" Value="#FFA000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="LOT Summary" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="Gray" Margin="6,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="(原始資料)"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSummaryCalculated}" Value="True">
                                        <Setter Property="Text" Value="(試算)"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,2,6">
                    <CheckBox Content="最新 N 片"
                              IsChecked="{Binding TopNEnabled}"
                              VerticalAlignment="Center"/>
                    <TextBox Width="50" Margin="6,0,4,0"
                             Text="{Binding TopN, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding TopNEnabled}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TopNWarning}"
                               Foreground="#E67E22" FontStyle="Italic"
                               VerticalAlignment="Center" Margin="2,0,12,0"/>

                    <TextBlock Text="Yield 模式:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="100"
                              ItemsSource="{Binding YieldModes}"
                              SelectedItem="{Binding YieldMode}"
                              VerticalAlignment="Center"/>

                    <CheckBox Content="CountETC?"
                              IsChecked="{Binding CountETC}"
                              Margin="14,0,0,0" VerticalAlignment="Center"
                              ToolTip="勾選 = 把 ETC 類視為缺陷計入良率分母；&#x0a;取消 = 將「只有 ETC 類缺陷」的基板視為良品（NGDie 計入 GDie）。&#x0a;ETC 類 = ETC / E.O. / LD / SD / Bridge。&#x0a;若批次內無 ETC 類缺陷造成 NG die，勾選與否結果相同。"/>

                    <TextBlock Text="DIE/Sub:" Margin="16,0,4,0" VerticalAlignment="Center"/>
                    <TextBox Width="60" VerticalAlignment="Center"
                             Text="{Binding DieBaseDieCount, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="預設自動偵測；手動輸入後覆寫"/>
                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Foreground="Gray">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding DieBaseDieCountAuto, StringFormat=(auto: {0})}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DieBaseHasAutoValue}" Value="False">
                                        <Setter Property="Text" Value="(請手動輸入)"/>
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Cycle Time 選項 -->
                    <Border BorderBrush="#CFCFCF" BorderThickness="1,0,0,0" Margin="16,2,0,2"/>
                    <CheckBox Content="僅 Stage=1"
                              IsChecked="{Binding CycleTimeStage1Only}"
                              Margin="14,0,0,0" VerticalAlignment="Center"
                              ToolTip="勾選 = 只計算 Stage=1 row 的 Cycle Time（實際生產節拍）&#x0a;取消 = 全部 row 都納入（含修補後重檢的時間間隔）"/>
                    <TextBlock Text="Gap 閾值:" Margin="14,0,4,0" VerticalAlignment="Center"
                               ToolTip="超過此秒數的間隔視為休息/換批，不計入平均"/>
                    <TextBox Width="50" VerticalAlignment="Center"
                             Text="{Binding CycleTimeMaxGapSeconds, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="預設 300 秒；可自訂"/>
                    <TextBlock Text="s" Margin="2,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 1: Top-N summary (visible only when TopNEnabled) -->
                <DockPanel Grid.Row="1" LastChildFill="True" Margin="0,0,0,4"
                           Visibility="{Binding IsTopNVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock DockPanel.Dock="Top" Text="最新 N 片"
                               FontWeight="Bold" Margin="2,0,2,2"/>
                    <!-- Right-side Cycle Time panel for Top-N -->
                    <Border DockPanel.Dock="Right" Width="170" Margin="6,0,0,0"
                            BorderBrush="#CFCFCF" BorderThickness="1"
                            Background="#FAFAFA" Padding="8,4">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Cycle Time (最新 N)" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding CycleTimeTopNDisplay}"
                                       FontSize="18" Foreground="#1565C0" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding CycleTimeTopNSampleDisplay}"
                                       FontSize="11" Foreground="#666" Margin="0,2,0,0"
                                       ToolTip="目前 Gap 閾值下實際納入平均計算的 Δt 樣本數"/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding TopNSummaryRows}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="All" FontSize="12"
                              MaxHeight="130"
                              VerticalScrollBarVisibility="Auto"
                              AlternationCount="2"
                              RowBackground="White"
                              AlternatingRowBackground="#EFF3F7">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding Label}" Width="100" FontWeight="Bold"/>
                            <DataGridTextColumn Header="OK" Binding="{Binding OK}" Width="65"/>
                            <DataGridTextColumn Header="Miss" Binding="{Binding Miss}" Width="55"/>
                            <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="55"/>
                            <DataGridTextColumn Header="SD" Binding="{Binding SD}" Width="45"/>
                            <DataGridTextColumn Header="LD" Binding="{Binding LD}" Width="45"/>
                            <DataGridTextColumn Header="ETC" Binding="{Binding ETC}" Width="55"/>
                            <DataGridTextColumn Header="Bridge" Binding="{Binding Bridge}" Width="55"/>
                            <DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="55"/>
                            <DataGridTextColumn Header="E.O." Binding="{Binding EO}" Width="50"/>
                            <DataGridTextColumn Header="NGDie" Binding="{Binding NGDie}" Width="55"/>
                            <DataGridTextColumn Header="GDie" Binding="{Binding GDie}" Width="50"/>
                            <DataGridTextColumn Header="PPM" Binding="{Binding PPM}" Width="65"/>
                            <DataGridTextColumn Header="Yield[%]" Binding="{Binding YieldPercent}" Width="75"/>
                            <DataGridTextColumn Header="Date / Time" Binding="{Binding DateTime}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Row 2: Full-lot summary (always visible) -->
                <DockPanel Grid.Row="2" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="整批"
                               FontWeight="Bold" Margin="2,0,2,2"
                               Visibility="{Binding IsTopNVisible, Converter={StaticResource BoolToVis}}"/>
                    <!-- Right-side Cycle Time panel for 整批 -->
                    <Border DockPanel.Dock="Right" Width="170" Margin="6,0,0,0"
                            BorderBrush="#CFCFCF" BorderThickness="1"
                            Background="#FAFAFA" Padding="8,4">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Cycle Time (整批)" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding CycleTimeOverallDisplay}"
                                       FontSize="18" Foreground="#1565C0" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding CycleTimeOverallSampleDisplay}"
                                       FontSize="11" Foreground="#666" Margin="0,2,0,0"
                                       ToolTip="目前 Gap 閾值下實際納入平均計算的 Δt 樣本數"/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding LotSummaryRows}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="All" FontSize="12"
                              MaxHeight="160"
                              VerticalScrollBarVisibility="Auto"
                              AlternationCount="2"
                              RowBackground="White"
                              AlternatingRowBackground="#EFF3F7">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding Label}" Width="100" FontWeight="Bold"/>
                            <DataGridTextColumn Header="OK" Binding="{Binding OK}" Width="65"/>
                            <DataGridTextColumn Header="Miss" Binding="{Binding Miss}" Width="55"/>
                            <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="55"/>
                            <DataGridTextColumn Header="SD" Binding="{Binding SD}" Width="45"/>
                            <DataGridTextColumn Header="LD" Binding="{Binding LD}" Width="45"/>
                            <DataGridTextColumn Header="ETC" Binding="{Binding ETC}" Width="55"/>
                            <DataGridTextColumn Header="Bridge" Binding="{Binding Bridge}" Width="55"/>
                            <DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="55"/>
                            <DataGridTextColumn Header="E.O." Binding="{Binding EO}" Width="50"/>
                            <DataGridTextColumn Header="NGDie" Binding="{Binding NGDie}" Width="55"/>
                            <DataGridTextColumn Header="GDie" Binding="{Binding GDie}" Width="50"/>
                            <DataGridTextColumn Header="PPM" Binding="{Binding PPM}" Width="65"/>
                            <DataGridTextColumn Header="Yield[%]" Binding="{Binding YieldPercent}" Width="75"/>
                            <DataGridTextColumn Header="Date / Time" Binding="{Binding DateTime}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </GroupBox>

        <!-- Main DataGrid (center) -->
        <DataGrid x:Name="MainDataGrid"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="All"
                  MouseDoubleClick="DataGrid_MouseDoubleClick"
                  VirtualizingStackPanel.IsVirtualizing="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background"
                            Value="{Binding Judge, Converter={StaticResource JudgeToRowColorConv}}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0078D7"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                <DataGridTextColumn Header="OK" Binding="{Binding OK}" Width="65"/>
                <DataGridTextColumn Header="Miss" Binding="{Binding Miss}" Width="55"/>
                <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="55"/>
                <DataGridTextColumn Header="SD" Binding="{Binding SD}" Width="45"/>
                <DataGridTextColumn Header="LD" Binding="{Binding LD}" Width="45"/>
                <DataGridTextColumn Header="ETC" Binding="{Binding ETC}" Width="55"/>
                <DataGridTextColumn Header="Bridge" Binding="{Binding Bridge}" Width="55"/>
                <DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="55"/>
                <DataGridTextColumn Header="E.O." Binding="{Binding EO}" Width="50"/>
                <DataGridTextColumn Header="NGDie" Binding="{Binding NGDie}" Width="55"/>
                <DataGridTextColumn Header="GDie" Binding="{Binding GDie}" Width="50"/>
                <DataGridTextColumn Header="PPM" Binding="{Binding PPM, StringFormat=F1}" Width="65"/>
                <DataGridTextColumn Header="Judge" Binding="{Binding Judge}" Width="55"/>
                <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="55"/>
                <DataGridTextColumn Header="Yield[%]" Binding="{Binding YieldPercent, StringFormat=F3}" Width="75"/>
                <DataGridTextColumn Header="Date / Time" Binding="{Binding DateTime}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
