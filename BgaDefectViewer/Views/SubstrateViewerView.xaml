<UserControl x:Class="BgaDefectViewer.Views.SubstrateViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BgaDefectViewer.Controls"
             xmlns:conv="clr-namespace:BgaDefectViewer.Converters">
    <UserControl.Resources>
        <conv:DefectCodeToColorConverter x:Key="DefectColorConv"/>
    </UserControl.Resources>
    <DockPanel>
        <!-- Header bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
            <TextBlock Text="WaferID: " FontSize="13"/>
            <TextBlock Text="{Binding WaferId}" FontSize="13" FontWeight="Bold"/>
            <TextBlock Text="  Recipe: " Margin="16,0,0,0" FontSize="13"/>
            <TextBlock Text="{Binding Recipe}" FontSize="13" FontWeight="Bold"/>
            <TextBlock Text="  INSPECTION: " Margin="16,0,0,0" FontSize="13"/>
            <ComboBox ItemsSource="{Binding InspectionNumbers}"
                      SelectedItem="{Binding SelectedInspection}" Width="60" VerticalAlignment="Center"/>
            <!-- Interaction mode buttons -->
            <ToggleButton x:Name="NormalModeBtn" Content="一般" IsChecked="True"
                          ToolTip="一般模式：點擊缺陷高亮，可拖曳畫面"
                          Margin="12,0,2,0" Padding="6,2" VerticalAlignment="Center"
                          Checked="NormalModeBtn_Checked" Unchecked="NormalModeBtn_Unchecked"/>
            <ToggleButton x:Name="ProbeModeBtn" Content="量測"
                          ToolTip="詳細鼠標模式：點擊灰點顯示坐標戳記，右鍵清除所有戳記"
                          Margin="2,0,0,0" Padding="6,2" VerticalAlignment="Center"
                          Checked="ProbeModeBtn_Checked" Unchecked="ProbeModeBtn_Unchecked"/>
            <ToggleButton x:Name="PreciseModeBtn" Content="精確量測"
                          ToolTip="精確量測模式：左鍵選起點，右鍵選終點，雙擊左鍵清除"
                          Margin="2,0,0,0" Padding="6,2" VerticalAlignment="Center"
                          Checked="PreciseModeBtn_Checked" Unchecked="PreciseModeBtn_Unchecked"/>
            <Button Content="FIT" Click="FitButton_Click"
                    Margin="8,0,0,0" Padding="8,2" VerticalAlignment="Center"
                    ToolTip="重置縮放以顯示整個裝置，並切換回一般模式"/>
        </StackPanel>

        <!-- Summary bar (bottom) -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="8,4">
            <TextBlock Text="{Binding SummaryText}" FontFamily="Consolas" FontSize="12"/>
        </Border>

        <!-- Main content: Canvas (left) + DataGrid (right) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <!-- Ball Map Canvas -->
            <Border Grid.Column="0" Background="#1E1E1E" ClipToBounds="True">
                <controls:BallMapCanvas x:Name="BallCanvas"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- Right Panel -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Margin="4">
                    <TextBlock FontSize="14" FontWeight="Bold">
                        <Run Text="Device Judge: "/>
                        <Run Text="{Binding DeviceJudge, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <DataGrid x:Name="DefectDataGrid"
                          ItemsSource="{Binding Defects}"
                          SelectedItem="{Binding SelectedDefect}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False"
                          GridLinesVisibility="All"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          SelectionChanged="DefectDataGrid_SelectionChanged"
                          MouseDoubleClick="DefectDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding BallId}"     Width="50"/>
                        <DataGridTextColumn Header="X"        Binding="{Binding DisplayX}"   Width="70"/>
                        <DataGridTextColumn Header="Y"        Binding="{Binding DisplayY}"   Width="70"/>
                        <DataGridTextColumn Header="Diameter" Binding="{Binding DisplayDia}" Width="75"/>
                        <DataGridTemplateColumn Header="Judge" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DefectName}"
                                               Background="{Binding DefectCode, Converter={StaticResource DefectColorConv}}"
                                               Padding="4,2" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
