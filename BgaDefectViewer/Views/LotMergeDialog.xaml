<Window x:Class="BgaDefectViewer.Views.LotMergeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="選擇要合併的 Lot#" Width="400" Height="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- 依日期分組視圖：Items 已由 LotMonitorViewModel.LotNumbers 預排（CreatedAt.Date desc
             + 次排序），PropertyGroupDescription 直接把相鄰同日項目聚成一組。GroupStyle 用灰字
             日期作為小標題，與 MainWindow Lot# 下拉視覺一致。 -->
        <CollectionViewSource x:Key="ItemsGroupedView" Source="{Binding Items}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="DateGroupKey"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="勾選 2 個以上 Lot 進行合併（僅本次 session 有效，不修改原始檔）。"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OkButton" Content="確定" Width="80" Margin="4,0"
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="取消" Width="80" Margin="4,0" IsCancel="True"/>
        </StackPanel>

        <ListBox ItemsSource="{Binding Source={StaticResource ItemsGroupedView}}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionChanged="LotList_SelectionChanged">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <!-- 「載入更多」哨兵自成一組 (DateGroupKey="__loadmore_group__")；
                                 隱藏其 header 讓哨兵以無分組標題形式停在列表末端。 -->
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#999" FontSize="11"
                                       Padding="6,4,6,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="__loadmore_group__">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 一般項目顯示 CheckBox；哨兵以強調色 TextBlock 提示「載入更多」，
                         CheckBox 被 DataTrigger 隱藏。實際展開動作在 ListBox.SelectionChanged
                         中處理（偵測 SelectedItem.IsLoadMore）。-->
                    <Grid Margin="2">
                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                  Content="{Binding DisplayName}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadMore}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="#0064C8" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Padding="4,4"
                                   Visibility="Collapsed">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadMore}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
